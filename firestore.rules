rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * UNO Web New Version - Security Rules
     * 
     * Core Philosophy: 
     * - User profiles and stats are owned by the user.
     * - Game rooms are publicly viewable by signed-in users so they can join/rejoin.
     * - Updates to game rooms are restricted to participants.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isParticipant(playerIds) {
      return isSignedIn() && request.auth.uid in playerIds;
    }

    // --- COLLECTION RULES ---

    match /userProfiles/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /playerStats/default {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      match /friendships/{friendshipId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    match /gameRooms/{roomId} {
      allow list: if isSignedIn();
      // Allow any signed-in user to GET a room so they can join it or view the lobby
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      // Allow update if the user is already a participant OR if they are currently adding themselves to the playerIds array
      allow update: if isSignedIn() && (
        isParticipant(resource.data.playerIds) || 
        isParticipant(request.resource.data.playerIds)
      );
      allow delete: if isSignedIn() && (
        resource.data.hostId == request.auth.uid || 
        isParticipant(resource.data.playerIds)
      );

      // Chat messages subcollection
      match /messages/{messageId} {
        allow list: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    match /gameSessions/{sessionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isParticipant(resource.data.playerIds);
      allow create: if isSignedIn() && isParticipant(request.resource.data.playerIds);
      allow update, delete: if false; 
    }
  }
}